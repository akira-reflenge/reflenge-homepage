---
import Layout from '../layouts/Layout.astro';
import { client } from '../library/microcms';
import type { Product } from '../library/microcms';

const response = await client.get({
  endpoint: "products", 
  queries: { limit: 32 }
});
const products: Product[] = response.contents;
---

<Layout title="導入製品・システム紹介 | 株式会社Reflenge">
  <main class="bg-white min-h-screen pt-32 pb-24 px-6">
    <div class="max-w-7xl mx-auto">
      
      <div class="flex flex-col gap-4 mb-16 animate-slide-up">
        <span class="text-primary font-bold tracking-[0.4em] uppercase text-xs md:text-sm">
        Case Studies
        </span>
        <h2 class="text-5xl font-bold text-deep-blue leading-tight editorial-title">導入事例</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-x-6 gap-y-12">
        {products.map((item) => (
          /* カード全体を枠線と背景、ホバー時の浮き上がりで強調 */
          <a href={`/products/${item.id}`} class="group block overflow-hidden bg-white border border-slate-100 rounded-xl p-4 transition-all duration-300 hover:shadow-xl hover:shadow-blue-900/5 hover:-translate-y-1">
            <div class="aspect-[4/3] mb-5 overflow-hidden bg-slate-100 rounded-lg">
              {item.eyecatch ? (
                <img 
                  src={item.eyecatch.url} 
                  alt={item.title}
                  class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
                />
              ) : (
                <div class="w-full h-full flex items-center justify-center text-slate-300 text-xs">No Image</div>
              )}
            </div>

            <div class="px-1 py-2 space-y-3">
              <div class="flex items-center gap-3">
                <time class="text-[11px] font-bold text-slate-400">
                  {new Date(item.publishedAt).toLocaleDateString('ja-JP').replace(/\//g, '.')}
                </time>
                {item.category && (
                  <span class="px-2 py-0.5 bg-accent-blue text-primary text-[9px] font-bold rounded-sm border border-blue-100 uppercase tracking-wider">
                    {item.category.name}
                  </span>
                )}
              </div>
              <h3 class="text-base font-bold text-deep-blue group-hover:text-primary transition-colors leading-snug line-clamp-2 min-h-[3rem]">
                {item.title}
              </h3>
              {item["company-name"] && (
                <p class="text-[11px] text-slate-400 font-medium">{item["company-name"]}</p>
              )}
              <div class="pt-1">
                <span class="text-[10px] font-bold text-deep-blue border-b border-deep-blue pb-0.5 group-hover:text-primary group-hover:border-primary transition-all uppercase tracking-widest">
                  Details
                </span>
              </div>
            </div>
          </a>
        ))}
      </div>

      {products.length === 0 && (
        <p class="text-slate-500 py-20 text-center font-medium">現在、掲載中の事例はありません。</p>
      )}
    </div>
  </main>
</Layout>