---
import Layout from '../../layouts/Layout.astro';
import { client } from '../../library/microcms';
import type { Product } from '../../library/microcms';

export async function getStaticPaths() {
  const response = await client.get({ endpoint: "products", queries: { limit: 100 } });
  return response.contents.map((item: Product) => ({
    params: { id: item.id },
  }));
}

const { id } = Astro.params;
const item = await client.getListDetail<Product>({
  endpoint: "products",
  contentId: id,
});
---

<Layout title={`${item.title} | 株式会社Reflenge`}>
  <main class="bg-white min-h-screen pt-40 pb-24 px-6">
    <article class="max-w-3xl mx-auto">
      <header class="mb-12">
        <div class="flex flex-col gap-4 mb-8">
          <span class="text-primary font-bold tracking-[0.4em] uppercase text-xs md:text-sm">
            Case Study Detail
          </span>
          <div class="flex items-center gap-4">
            <time class="text-sm font-bold text-slate-400">
              {new Date(item.publishedAt).toLocaleDateString('ja-JP').replace(/\//g, '.')}
            </time>
            {item.category && (
              <span class="px-3 py-1 bg-accent-blue text-primary text-[10px] font-bold rounded-sm border border-blue-100 uppercase tracking-wider">
                {item.category.name}
              </span>
            )}
          </div>
        </div>

        <h1 class="text-3xl md:text-4xl font-bold text-deep-blue leading-tight mb-4">
          {item.title}
        </h1>
        {item["company-name"] && (
          <p class="text-sm text-slate-500 font-medium mb-8">導入企業：{item["company-name"]}</p>
        )}

        {item.eyecatch && (
          <img 
            src={item.eyecatch.url} 
            alt="" 
            class="w-full rounded-2xl shadow-sm"
          />
        )}
      </header>

      <div 
        class="prose prose-slate max-w-none prose-headings:text-deep-blue prose-a:text-primary" 
        set:html={item.content} 
      />
      
      <div class="mt-20 pt-10 border-t border-slate-100">
        <a href="/products" class="text-sm font-bold text-slate-400 hover:text-primary transition-colors flex items-center gap-2">
          ← Back to Case Studies
        </a>
      </div>
    </article>
  </main>
</Layout>