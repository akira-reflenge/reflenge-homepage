---
/* src/pages/privacy.astro */
import Layout from '../layouts/Layout.astro';
---

<Layout title="個人情報保護方針 | 株式会社Reflenge">
  <main class="bg-white min-h-screen">
    <section class="relative pt-32 pb-16 px-6 bg-neutral/50">
      <div class="max-w-4xl mx-auto">
        <div class="flex flex-col gap-4 animate-slide-up">
          <span class="text-primary font-bold tracking-[0.4em] uppercase text-xs">
            Privacy Policy
          </span>
          <h1 class="text-4xl font-bold text-deep-blue leading-tight editorial-title">個人情報保護方針</h1>
        </div>
      </div>
    </section>

    <section class="py-20 px-6">
      <div class="max-w-4xl mx-auto">
        <div class="prose prose-slate max-w-none">
          <p class="text-slate-600 leading-loose mb-12">
            株式会社Reflenge（以下「当社」）は、IT ソリューションを提供する企業として、お客さま、取引先、および従業員等の個人情報を適切に保護・管理することを重要な社会的責任と認識し、以下の方針に基づき、個人情報の保護に努めます。
          </p>

          <div class="space-y-12">
            <div class="border-l-2 border-primary pl-6">
              <h2 class="text-xl font-bold text-deep-blue mb-4">1. 個人情報の取得・利用・提供</h2>
              <p class="text-slate-600 text-sm leading-relaxed">
                当社は、業務上必要な範囲で、適法かつ公正な手段により個人情報を取得し、取得時に明示した利用目的の範囲内でのみ利用します。また、ご本人の同意を得ることなく第三者に提供することはありません。
              </p>
            </div>

            <div class="border-l-2 border-primary pl-6">
              <h2 class="text-xl font-bold text-deep-blue mb-4">2. 安全管理措置</h2>
              <p class="text-slate-600 text-sm leading-relaxed">
                当社は、個人情報の漏えい、滅失、き損、改ざん、及び不正アクセス等のリスクに対し、必要かつ適切な安全管理措置を講じます。
              </p>
            </div>

            <div class="border-l-2 border-primary pl-6">
              <h2 class="text-xl font-bold text-deep-blue mb-4">3. 個人情報の保管</h2>
              <p class="text-slate-600 text-sm leading-relaxed">
                当社が保有する個人情報について、漏えいや滅失、毀損等を防止するため、厳格な管理のもとで安全に蓄積・保管します。また、万一の発生時には速やかに適切な対応を行います。
              </p>
            </div>

            <div class="border-l-2 border-primary pl-6">
              <h2 class="text-xl font-bold text-deep-blue mb-4">4. ご本人の権利尊重</h2>
              <p class="text-slate-600 text-sm leading-relaxed">
                当社の保有する個人情報について、本人から開示・訂正・利用停止などの要求やお問い合せ、苦情や相談があった場合には、適切に対応します。
              </p>
            </div>

            <div class="border-l-2 border-primary pl-6">
              <h2 class="text-xl font-bold text-deep-blue mb-4">5. 教育と周知</h2>
              <p class="text-slate-600 text-sm leading-relaxed">
                当社は、役員および従業員に対し、個人情報保護の重要性を理解させ、適切な取り扱いが行われるよう教育と周知を行います。
              </p>
            </div>

            <div class="border-l-2 border-primary pl-6">
              <h2 class="text-xl font-bold text-deep-blue mb-4">6. お問い合わせ対応</h2>
              <p class="text-slate-600 text-sm leading-relaxed">
                当社は、保有する個人情報について、ご本人からの開示、訂正、削除、利用停止等のご請求、及び苦情や相談に対して、迅速かつ誠実に対応いたします。
              </p>
            </div>
          </div>

          <div class="mt-20 pt-10 border-t border-slate-100 text-right">
            <p class="text-sm text-slate-500 font-bold">株式会社Reflenge</p>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>