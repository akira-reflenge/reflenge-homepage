---
/* src/components/Header.astro */
---
<nav id="main-nav" class="fixed top-0 left-0 w-full h-20 bg-white/90 backdrop-blur-md border-b border-gray-100 flex items-center justify-between px-6 md:px-8 z-[100] transition-shadow duration-300 transition-border duration-300">
  <a href="/" class="flex items-center gap-4 header-logo">
    <div class="w-10 h-10">
      <img src="/ロゴ.png" alt="Reflenge Logo" class="w-full h-full object-contain" />
    </div>
    <div class="flex flex-col">
      <span class="text-xl font-bold tracking-tighter text-[#001A4D] leading-none">株式会社Reflenge</span>
      <span class="text-[8px] font-bold tracking-[0.4em] text-gray-400 mt-1 uppercase">Respond flexibly to change</span>
    </div>
  </a>

  <div class="hidden lg:flex items-center gap-10">
    <div class="dropdown-wrapper nav-item" style="animation-delay: 0.1s">
      <a href="/about" class="nav-link">ABOUT US</a>
      <div class="dropdown-menu">
        <a href="/about#message">メッセージ</a>
        <a href="/about#company-info">会社情報</a>
        <a href="/about#access">アクセス</a>
      </div>
    </div>
    <div class="dropdown-wrapper nav-item" style="animation-delay: 0.2s">
      <a href="/services" class="nav-link">SERVICES</a>
      <div class="dropdown-menu">
        <a href="/services#ai">AIアプリ開発</a>
        <a href="/services#consulting">業務改善コンサル</a>
        <a href="/services#system">システム開発</a>
        <a href="/services#it-strategy">ITコンサルティング</a>
        <a href="/services#web">WEB制作</a>
      </div>
    </div>
    <a href="/products" class="nav-link nav-item" style="animation-delay: 0.3s">CASE STUDIES</a>
    <a href="/solutions" class="nav-link nav-item" style="animation-delay: 0.4s">OUR PRODUCTS</a>
    <a href="/news" class="nav-link nav-item" style="animation-delay: 0.5s">NEWS</a>
    <a href="/#contact" class="contact-btn nav-item" style="animation-delay: 0.6s">GET IN TOUCH</a>
  </div>

  <button id="menu-open-btn" class="lg:hidden flex flex-col justify-center items-center w-10 h-10 gap-1.5">
    <span class="w-6 h-0.5 bg-[#001A4D]"></span>
    <span class="w-6 h-0.5 bg-[#001A4D]"></span>
    <span class="w-6 h-0.5 bg-[#001A4D]"></span>
  </button>
</nav>

<div id="mobile-menu" class="mobile-menu-overlay">
  <button id="menu-close-btn" class="absolute top-5 right-6 w-10 h-10 flex flex-col justify-center items-center">
    <span class="w-6 h-0.5 bg-[#001A4D] rotate-45 translate-y-[1px]"></span>
    <span class="w-6 h-0.5 bg-[#001A4D] -rotate-45 -translate-y-[1px]"></span>
  </button>

  <div class="flex flex-col items-center gap-8">
    <a href="/about" class="nav-link-mobile">ABOUT US</a>
    <a href="/services" class="nav-link-mobile">SERVICES</a>
    <a href="/products" class="nav-link-mobile">CASE STUDIES</a>
    <a href="/solutions" class="nav-link-mobile">OUR PRODUCTS</a>
    <a href="/news" class="nav-link-mobile">NEWS</a>
    <a href="/#contact" class="mobile-contact-btn">GET IN TOUCH</a>
  </div>
</div>

<style>
  /* ===== 入場アニメーション ===== */
  @keyframes header-fade-in {
    from { opacity: 0; transform: translateY(-10px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .header-logo {
    animation: header-fade-in 0.6s ease forwards;
  }

  .nav-item {
    opacity: 0;
    animation: header-fade-in 0.5s ease forwards;
  }

  /* ===== スクロール連動 ===== */
  #main-nav.scrolled {
    box-shadow: 0 2px 20px rgba(0, 0, 0, 0.08);
    border-bottom-color: rgba(0, 0, 0, 0.08);
  }

  /* ===== ナビリンク hover 下線アニメーション ===== */
  .nav-link { font-size: 13px; font-weight: 900; letter-spacing: 0.15em; color: #001A4D; text-decoration: none; position: relative; }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -3px;
    left: 0;
    width: 0;
    height: 1.5px;
    background: #003399;
    transition: width 0.3s ease;
  }

  .nav-link:hover::after { width: 100%; }

  /* ===== ドロップダウン ===== */
  .dropdown-wrapper { position: relative; display: flex; align-items: center; }

  .dropdown-menu {
    position: absolute;
    top: calc(100% + 16px);
    left: 50%;
    transform: translateX(-50%) translateY(-6px);
    background: white;
    border: 1px solid rgba(0, 0, 0, 0.06);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
    min-width: 180px;
    padding: 8px 0;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.2s ease, transform 0.2s ease, visibility 0.2s;
    z-index: 200;
  }

  .dropdown-wrapper:hover .dropdown-menu {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
  }

  .dropdown-menu a {
    display: block;
    padding: 10px 20px;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.05em;
    color: #001A4D;
    text-decoration: none;
    transition: background 0.15s ease;
    white-space: nowrap;
  }

  .dropdown-menu a:hover { background: #f5f7ff; }

  .contact-btn { background: #001A4D; color: white; padding: 0.8rem 2rem; font-size: 12px; font-weight: 900; letter-spacing: 0.2em; text-decoration: none; }

  .mobile-menu-overlay {
    position: fixed !important;
    inset: 0 !important;
    background-color: white !important;
    z-index: 1000 !important; /* 最前面 */
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    transform: translateX(100%);
    transition: transform 0.4s ease;
    visibility: hidden;
  }

  .mobile-menu-overlay.active {
    transform: translateX(0) !important;
    visibility: visible !important;
  }

  .nav-link-mobile { font-size: 24px; font-weight: 900; color: #001A4D; text-decoration: none; letter-spacing: 0.1em; }
  .mobile-contact-btn { background: #001A4D; color: white !important; padding: 1rem 2.5rem; font-weight: 900; text-decoration: none; }
</style>

<script is:inline>
  function initMenu() {
    const openBtn = document.getElementById('menu-open-btn');
    const closeBtn = document.getElementById('menu-close-btn');
    const menu = document.getElementById('mobile-menu');
    const links = document.querySelectorAll('#mobile-menu a');

    if (!openBtn || !closeBtn || !menu) return;

    // 開く
    openBtn.onclick = () => {
      menu.classList.add('active');
      document.body.style.overflow = 'hidden';
    };

    // 閉じる
    closeBtn.onclick = () => {
      menu.classList.remove('active');
      document.body.style.overflow = '';
    };

    // リンククリックで閉じる
    links.forEach(link => {
      link.onclick = () => {
        menu.classList.remove('active');
        document.body.style.overflow = '';
      };
    });
  }

  initMenu();
  document.addEventListener('astro:after-swap', initMenu);

  // スクロール連動: ヘッダーにシャドウを付与
  function initScrollEffect() {
    const nav = document.getElementById('main-nav');
    if (!nav) return;
    const onScroll = () => {
      nav.classList.toggle('scrolled', window.scrollY > 20);
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }

  initScrollEffect();
  document.addEventListener('astro:after-swap', initScrollEffect);
</script>