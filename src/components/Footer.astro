---
/* src/components/Footer.astro */
const sitemap = [
  { name: '会社概要', href: '/about' },
  { name: '事業内容', href: '/services' },
  { name: '導入事例', href: '/products' },
  { name: 'お知らせ', href: '/news' },
];

const services = [
  { name: 'AIアプリ開発', href: '/services#ai' },
  { name: '業務改善コンサル', href: '/services#consulting' },
  { name: 'システム開発', href: '/services#system' },
  { name: 'ITコンサルティング', href: '/services#it-strategy' },
  { name: 'WEB制作', href: '/services#web' },
];

const contactLinks = [
  { name: 'お問い合わせ', href: '/#contact' },
  { name: 'プライバシーポリシー', href: '/privacy' }, 
];
---

<footer class="bg-[#050505] text-white pt-32 pb-12">
  <div class="max-w-7xl mx-auto px-8">
    
    <div class="grid grid-cols-2 lg:grid-cols-12 gap-x-8 gap-y-16 mb-24">
      
      <div class="col-span-2 lg:col-span-4 space-y-8">
        <a href="/" class="flex items-center gap-4 group">
          <div class="w-10 h-10 flex items-center justify-center transition-transform group-hover:scale-110">
            <img 
              src="/ロゴ.png" 
              alt="Reflenge Logo" 
              class="w-full h-full object-contain" 
            />
          </div>
          <span class="text-2xl font-bold tracking-tighter">Reflenge</span>
        </a>
        <p class="text-sm text-gray-500 leading-loose max-w-sm">
          私たちは、最新のテクノロジーと確かな信頼で、<br/>企業の変革を支えるITパートナーです。
        </p>
        <div class="space-y-2 pt-4">
           <p class="text-[10px] text-gray-600 tracking-widest uppercase font-bold">Location</p>
           <p class="text-xs text-gray-400">〒782-0003 高知県香美市土佐山田町宮ノ口185 地域連携棟304A号室</p>
        </div>
      </div>

      <div class="col-span-1 lg:col-span-2 space-y-8">
        <p class="text-[10px] text-primary tracking-[0.3em] uppercase font-bold">Sitemap</p>
        <ul class="space-y-4">
          {sitemap.map(link => (
            <li>
              <a href={link.href} class="text-sm text-gray-400 hover:text-white transition-colors">
                {link.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div class="col-span-1 lg:col-span-3 space-y-8">
        <p class="text-[10px] text-primary tracking-[0.3em] uppercase font-bold">Services</p>
        <ul class="space-y-4">
          {services.map(link => (
            <li>
              <a href={link.href} class="text-sm text-gray-400 hover:text-white transition-colors">
                {link.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div class="col-span-2 lg:col-span-3 space-y-8">
        <p class="text-[10px] text-primary tracking-[0.3em] uppercase font-bold">Contact & Legal</p>
        <ul class="space-y-4">
          {contactLinks.map(link => (
            <li>
              <a href={link.href} class="text-sm text-gray-400 hover:text-white transition-colors">
                {link.name}
              </a>
            </li>
          ))}
        </ul>
        <div class="flex gap-6 pt-4">
          <a 
            href="https://x.com/reflenge_jp?s=21" 
            target="_blank" 
            rel="noopener noreferrer" 
            class="text-gray-500 hover:text-primary transition-colors"
          >
            <span class="text-xs font-bold tracking-widest">X (Twitter)</span>
          </a>
          <a 
            href="https://www.instagram.com/reflenge?igsh=MW10cDUzOWVpNm9lMg==" 
            target="_blank" 
            rel="noopener noreferrer" 
            class="text-gray-500 hover:text-primary transition-colors"
          >
            <span class="text-xs font-bold tracking-widest">Instagram</span>
          </a>
        </div>
      </div>

    </div>

    <div class="pt-12 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-8">
      <p class="text-[9px] text-gray-600 tracking-[0.4em] font-bold uppercase">
        © 2026 REFLENGE INC. ALL RIGHTS RESERVED.
      </p>
      <div class="flex gap-8">
         <button onclick="window.scrollTo({top: 0, behavior: 'smooth'})" class="text-[9px] text-gray-400 hover:text-white tracking-widest uppercase font-bold transition-colors">
            Back to Top ↑
         </button>
      </div>
    </div>

  </div>
</footer>